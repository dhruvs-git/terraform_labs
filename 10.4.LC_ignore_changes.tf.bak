terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
}

provider "aws" {
  region  = "ca-central-1"
  profile = "terralearn"
}

resource "aws_instance" "myec2" {
    ami = "ami-066ab5c7bf87a3e58"
    instance_type = "t3.micro"
    tags = {
     Name = "terraform_ec2" 
    }
    
    lifecycle {
      ignore_changes = [tags]
    }
}

