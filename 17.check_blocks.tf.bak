terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
}

provider "aws" {
  region  = "ca-central-1"
  profile = "terralearn"
}

check "website_check" {
  data "http" "google_check" {
    url = "https://google.com"
  }

  assert {
    condition     = data.http.google_check.status_code == 200
    error_message = "website not running"
  }
}

resource "aws_iam_user" "myusers" {
  name = "heyya"
}